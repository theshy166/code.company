prefix=/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi
exec_prefix=/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi
libdir=/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/lib
includedir=/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/include

Name: liblzma
Description: General purpose data compression library
URL: https://tukaani.org/xz/
Version: 5.2.5
Cflags: -I${includedir}
Libs: -L${libdir} -llzma
Libs.private: -pthread -lpthread
