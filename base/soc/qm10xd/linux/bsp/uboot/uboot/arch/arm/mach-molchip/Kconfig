        bool "QM10XD ESL"
        help
          Support for ESL variants.


config UBOOT_SMARTDOOR
        bool "QM10XD SMARTDOOR"
        help
          Support for SMARTDOOR variants.

config UBOOT_CB1LD
        bool "QM10XD Core board v1"
        help
          Support for core board variants.
endmenu

