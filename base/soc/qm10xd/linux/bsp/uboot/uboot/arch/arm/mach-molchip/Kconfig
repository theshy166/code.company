menu "MOLCHIP ARM64 FAMILY"
        depends on ARCH_MOLCHIP

choice
        prompt "MOLCHIP ARM64 board select"
        optional

config TARGET_FY12
        bool "molchip fy12 evb"
        help
          Support for all molchip-based  variants.
          This option creates a build targetting the ARMv8/AArch64 ISA.
	select MOLCHIP
endchoice

config SYS_SOC
        default "molchip"

config UBOOT_WIFIX
        bool "QM10XD WIFIX"
        help
          Support for WIFIX  variants.

