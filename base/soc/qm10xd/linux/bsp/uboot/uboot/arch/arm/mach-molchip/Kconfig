config MOLCHIP
	bool "MOLCHIP  SoC support"
	depends on ARCH_MOLCHIP
	select ARMV8_LPAE if ARM64
	select CPU_V7	if !ARM64

menu "MOLCHIP xxx family"
	depends on ARCH_MOLCHIP

choice
	prompt "MOLCHIP xxx board select"
	optional

config TARGET_MOLCHIP
	bool "molchip xxx evb"
	help
	  Support for all molchip-based  variants.

	  This option creates a build targetting the ARMv7/AArch32 ISA.
	select MOLCHIP

config TARGET_TS01
	bool "molchip ts01 evb"
        help
          Support for all molchip-based  variants.

          This option creates a build targetting the ARMv7/AArch32 ISA.
        select MOLCHIP


config TARGET_FY01
