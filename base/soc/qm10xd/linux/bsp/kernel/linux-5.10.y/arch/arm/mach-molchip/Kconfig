menuconfig ARCH_MOLCHIP
	bool "MOLCHIP Ltd. family"
	depends on ARCH_MULTI_V7
	select ARCH_SUPPORTS_BIG_ENDIAN
	select ARM_AMBA
	select ARM_GIC
	select ARM_GLOBAL_TIMER
	select ARM_TIMER_SP804
	select COMMON_CLK_MOLCHIP
	select GPIOLIB
	select HAVE_ARM_SCU if SMP
	select HAVE_ARM_TWD if SMP
	select HAVE_PATA_PLATFORM
	select NO_IOPORT_MAP
	select PLAT_MOLCHIP
	select POWER_RESET
	select POWER_SUPPLY
	select REGULATOR if MMC_ARMMMCI
	select REGULATOR_FIXED_VOLTAGE if REGULATOR
	select MFD_MOLCHIP_SYSREG
	select VFP
	select DW_APB_TIMER_OF
	select PINCTRL
	help
	  This option enables support for systems using Cortex processor based
	  ARM core and logic (FPGA) tiles on the MOLCHIP motherboard,
	  for example:

	  - TS01
	  - FY01

	  You must boot using a Flattened Device Tree in order to use these
	  platforms. The traditional (ATAGs) boot method is not usable on
	  these boards with this option.

if ARCH_MOLCHIP

config PLAT_MOLCHIP
	def_bool y
	help
	  Base platform code for any molchip device

config MACH_TS01
        bool "Molchip TS01 SoCs support"
        depends on ARCH_MOLCHIP

config MACH_FY01
        bool "Molchip FY01 SoCs support"
        depends on ARCH_MOLCHIP

config MACH_FY00
        bool "Molchip FY00 SoCs support"
        depends on ARCH_MOLCHIP

config MACH_FY02
        bool "Molchip FY02 SoCs support"
        depends on ARCH_MOLCHIP

config MACH_FY02P
        bool "Molchip FY02 SoCs support"
        depends on ARCH_MOLCHIP

config MACH_FY10P
        bool "Molchip FY02 SoCs support"
        depends on ARCH_MOLCHIP

config MACH_XC01
        bool "Molchip XC01 SoCs support"
        depends on ARCH_MOLCHIP

config ARCH_MOLCHIP_CORTEX_A5_A9_ERRATA
	bool "Enable A5 and A9 only errata work-arounds"
	default y
	select ARM_ERRATA_643719 if SMP
	select ARM_ERRATA_720789
	select PL310_ERRATA_753970 if CACHE_L2X0
	help
	  Provides common dependencies for Versatile Express platforms
	  based on Cortex-A5 and Cortex-A9 processors. In order to
	  build a working kernel, you must also enable relevant core
	  tile support or Flattened Device Tree based support options.

config ARCH_MOLCHIP_DCSCB
	bool "Dual Cluster System Control Block (DCSCB) support"
	depends on MCPM
	select ARM_CCI400_PORT_CTRL
	help
	  Support for the Dual Cluster System Configuration Block (DCSCB).
	  This is needed to provide CPU and cluster power management
	  on RTSM implementing big.LITTLE.

config ARCH_MOLCHIP_SPC
	bool "MOLCHIP Serial Power Controller (SPC)"
	select PM_OPP
	help
	  The TC2 (A15x2 A7x3) versatile express core tile integrates a logic
	  block called Serial Power Controller (SPC) that provides the interface
	  between the dual cluster test-chip and the M3 microcontroller that
	  carries out power management.

config ARCH_MOLCHIP_TC2_PM
	bool "Versatile Express TC2 power management"
	depends on MCPM
	select ARM_CCI400_PORT_CTRL
	select ARCH_MOLCHIP_SPC
	select ARM_CPU_SUSPEND
	help
	  Support for CPU and cluster power management on Versatile Express
	  with a TC2 (A15x2 A7x3) big.LITTLE core tile.

config ARCH_MOLCHIP_DEBUG
	bool "Enable molchip debug feature"
	default n
	help
	  Support molchip debug feature

config MOLCHIP_FASTBOOT
	bool "Enable molchip fastboot feature"
	default n
	help
	  Support molchip fastboot feature

config PROJ_XKPHOTO
	bool "project feature"
	default n
	help
	  Support xkphoto feature

config PROJ_ESL
	bool "project feature"
	default n
	help
	  Support esl feature

config ARCH_MOLCHIP_SUSPEND
	bool "Enable molchip suspend feature"
	default n
	help
	  Support molchip suspend feature
endif
