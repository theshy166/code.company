		clock-frequency = <400000>;
		i2c-sda-hold-time-ns = <0xc8>;
		i2c-sda-falling-time-ns = <200>;
		i2c-scl-falling-time-ns = <200>;
		pinctrl-names = "default";
		pinctrl-0 = <&i2c0_pins>;
		status = "okay";
	};

