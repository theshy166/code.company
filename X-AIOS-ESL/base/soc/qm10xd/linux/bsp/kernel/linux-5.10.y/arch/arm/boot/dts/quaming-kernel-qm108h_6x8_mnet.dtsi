		#size-cells = <0>;
		compatible = "molchip,i2c";
		reg = <0x18100000 0x100>;
		clocks = <&topsys_gate CKG_I2C2_EN>,<&topsys_gate CKG_APB_I2C2_EN>,<&topsys_compostite CKG_MUX_I2C2>;
