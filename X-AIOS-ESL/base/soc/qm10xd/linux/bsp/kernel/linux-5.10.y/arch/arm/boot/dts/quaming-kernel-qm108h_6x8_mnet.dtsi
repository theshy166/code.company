	vou: vou@22200000 {
                compatible = "molchip,mc-vou";
                interrupts = <GIC_SPI 105 IRQ_TYPE_LEVEL_HIGH>;
                reg = <0x22200000 0x2000>;
                clock-names = "vou_clk_en",
                        "vou_apb_clk_en";
                clocks = <&vousys CKG_VOU400_EN>,
                        <&topsys_gate CKG_GLB_APB_VOU_EN>;
                status = "okay";
        };

        acw: acw@1cc00000 {
                compatible = "molchip,acw";
                reg = <0x1CC00000 0x1000>;
                interrupts = <GIC_SPI 32 IRQ_TYPE_LEVEL_HIGH>;
                clock-names = "clk_acw_en";
                clocks = <&veusys CKG_APB_AUDIO_CODEC_EN>;
                molchip,dma-rx-id = <40>;
                molchip,dma-tx-id = <39>;
                status = "okay";
        };

        dmic: acw@0a200000 {
                compatible = "molchip,dmic";
                reg = <0x0a200000 0x1000>,
                        <0x0A300000 0x1000>;
                interrupts = <GIC_SPI 29 IRQ_TYPE_LEVEL_HIGH>,
                        <GIC_SPI 28 IRQ_TYPE_LEVEL_HIGH>;
                clock-names = "apb_clk_en0",
                        "dmic_clk_en0",
                        "dmic_mux_en0",
                        "apb_clk_en1",
                        "dmic_clk_en1",
                        "dmic_mux_en1";
                clocks = <&cpusys_gatemux CKG_APB_DMIC0_EN>,
                        <&cpusys_gatemux CKG_DMIC0_EN>,
                        <&cpusys_gatemux CKG_MUX_DMIC0>,
                        <&cpusys_gatemux CKG_APB_DMIC1_EN>,
                        <&cpusys_gatemux CKG_DMIC1_EN>,
                        <&cpusys_gatemux CKG_MUX_DMIC1>;
                status = "okay";
        };


		vdsp: vdsp@20100000 {
			compatible = "molchip,mc-vdsp";
			mc,syscon = <&vou_sys_clk>;
			reg = <0x20100000 0x0>;
			interrupts = <GIC_SPI 117 IRQ_TYPE_LEVEL_HIGH>;
			status = "okay";
		};

	sdmmc0: dwmmc@1d400000 {
		compatible = "molchip,dw-mshc";
		reg = <0x1d400000 0x400>;
		//mc,peripheral-syscon = <&veu_sys_apb>;
		interrupts = <GIC_SPI 41 IRQ_TYPE_LEVEL_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&sdmmc0_pins>;
		mc,hsif = <&veu_sys_clk>;
		clock-frequency = <50000000>;
		clock-names = "biu",
			"ciu",
			"dllref",
			"sdioclk";
		clocks = <&veusys CKG_AHB_SDIO0_EN>,
				 <&veusys CKG_SDIO0_EN>,
				 <&veusys CKG_SDIO0_DLLREF_EN>,
				<&veusys CKG_MUX_SDIO0>;
		cap-sd-highspeed;
		//sd-uhs-ddr50;
		//sd-uhs-sdr25;
		//sd-uhs-sdr12;
		bus-width = <4>;
		status = "okay";
	};
	sdmmc1: dwmmc@1d300000 {
		compatible = "molchip,dw-mshc";
		non-removable;
		reg = <0x1d300000 0x400>;
		//mc,peripheral-syscon = <&veu_sys_apb>;
		interrupts = <GIC_SPI 42 IRQ_TYPE_LEVEL_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&sdmmc1_pins>;
		/*ctrl = <0x00cc>;
		ctrl2 = <0xf0>;
		dlloutstatus_spl = <0x0170>;
		dlloutstatus_drv = <0x017c>;
		dllinctrlreg_spl = <0x0168>;
		dllininforeg_spl = <0x016c>;
		dllinctrlreg_drv = <0x0174>;
		dllininforeg_drv = <0x0178>;
		clock-names = "biu",
			"ciu",
			"dllref",
			"sdioclk";
		clocks = <&apahb_gate CKG_SYS_SDIO1>,
			 <&apahb_gate CKG_SDIO1>,
			 <&apahb_gate CKG_SDIO1_DLLREF>,
			<&apclk CLK_MUX_SDIO1>;*/
		status = "disabled";
	};
	usb3_0: usb30@0 {
		compatible = "molchip,dwc3";
		#address-cells = <1>;
		#size-cells = <1>;

		ranges;

		status = "okay";

		dwc3: dwc3@2d400000 {
			/*clock-names = "otg";*/
			/*clocks = <&hsif_clk CKG_AXI_USB3_EN>;*/
			compatible = "snps,dwc3";
			#address-cells = <1>;
			#size-cells = <0>;
			reg = <0x2d400000 0x40000>;
			interrupts = <GIC_SPI 78 IRQ_TYPE_LEVEL_HIGH>;
			/*interrupt-names = "peripheral";*/
			/*dr_mode = "peripheral";*/
			interrupt-names = "host";
			dr_mode = "host";
			phy_type = "utmi_wide";
			snps,dis_u3_susphy_quirk;
			snps,dis_u2_susphy_quirk;
			phys = <&usb2_phy>, <&usb3_phy>;
			phy-names = "usb2-phy", "usb3-phy";
		};
	};

	usb2_phy: usb2-phy {
		compatible = "snps,usb2-phy";
		#phy-cells = <0>;
		status = "okay";
	};

	usb3_phy: usb3-phy {
		compatible = "molchip,usb3-phy";
		clock-names = "ckg_apb_usb3_cfg_en","ckg_axi_usb3_en",
				"ckg_usb3_suspend_sel","ckg_usb3_suspend_en",
				"ckg_usb32_ref_sel","ckg_usb32_ref_en";
		clocks = <&ispsys CKG_APB_USB3_CFG_EN>,<&ispsys CKG_AXI_USB3_EN>,
				<&ispsys CKG_MUX_USB3_SUSPEND>,<&ispsys CKG_USB3_SUSPEND_EN>,
				<&ispsys CKG_MUX_USB32_REF>,<&ispsys CKG_USB32_REF_EN>;
		molchip,syscon-clk-gate = <&isp_sys_clk>;
		molchip,syscon-usb3-cfg = <&usb3_apb_cfg_1>;
		#phy-cells = <0>;
		status = "okay";
	};
	lcm: lcm@20400000 {
                compatible = "molchip,mc-lcm";
                status = "okay";
        };

	rtc: rtc@18E00000 {
                compatible = "mc,xc01-rtc";
		clocks = <&topsys_gate CKG_APB_RTCT_EN>;
		clock-names = "ckg_apb_rtct_en";
                interrupts = <GIC_SPI 52 IRQ_TYPE_LEVEL_HIGH>;
                reg = <0x18E00000 0x400>;
		analog_thm_top = <&pllsrc>;
                nvmem-cells = <&tsens_calib>,
				<&tsens_thm_calib>;
                nvmem-cell-names = "calib","calib_thm";
                rtc-slope = <53000>;
                rtc-precision-ctrl = <1000000>;
                rtc-production-line-temp = <70>;
                rtc-precision-frc-ctrl = <10000>;
                rtc-default-intercept = <2220>;
                status = "okay";
        };

		syscfg_pctl: syscfg_pctrl@10200000 {
		compatible = "molchip,xc01-pctl-syscfg", "syscon";
		reg = <0x10200000 0x1000>;
	};

	syscfg_pctl_a: syscfg_pctrl_a@2F000000 {
		compatible = "molchip,xc01-pctl-a-syscfg", "syscon";
		reg = <0x2F000000 0x200>;
	};

	syscfg_pctl_b: syscfg_pctrl_b@2F100000 {
		compatible = "molchip,xc01-pctl-b-syscfg", "syscon";
		reg = <0x2F100000 0x100>;
	};

	syscfg_pctl_c: syscfg_pctrl_c@1F000000 {
		compatible = "molchip,xc01-pctl-c-syscfg", "syscon";
		reg = <0x1F000000 0x300>;
	};

	syscfg_pctl_d: syscfg_pctrl_d@1F100000 {
		compatible = "molchip,xc01-pctl-d-syscfg", "syscon";
		reg = <0x1F100000 0x1000>;
	};

	pinctrl: pinctrl@10200000 {
		compatible = "molchip,xc01-pinctrl";
		reg = <0x10200000 0x1000>;
		status = "okay";
		molchip,pctl-regmap = <&syscfg_pctl &syscfg_pctl_a &syscfg_pctl_b &syscfg_pctl_c &syscfg_pctl_d>;
		pins-are-numbered;

		i2c0_pins:i2c0_pins {
			pins1 {
				pinmux = <MCXC01_PIN_4_G0PAD4_FUNC_I2C0_SCL>, <MCXC01_PIN_5_G0PAD5_FUNC_I2C0_SDA>;
			};
		};
		i2c1_pins:i2c1_pins {
			pins1 {
				pinmux = <MCXC01_PIN_8_G0PAD8_FUNC_I2C1_SCL>, <MCXC01_PIN_9_G0PAD9_FUNC_I2C1_SDA>;
			};
		};
		i2c2_pins:i2c2_pins {
			pins1 {
				pinmux = <MCXC01_PIN_78_SADC_PAD1_FUNC_I2C2_SCL>, <MCXC01_PIN_79_SADC_PAD2_FUNC_I2C2_SDA>;
			};
		};
		i2c3_pins:i2c3_pins {
			pins1 {
				pinmux = <MCXC01_PIN_65_G3PAD10_FUNC_I2C3_SCL>, <MCXC01_PIN_66_G3PAD11_FUNC_I2C3_SDA>;
			};
		};
		spi0_pins:spi0_pins {
			pins1 {
				pinmux = <MCXC01_PIN_49_G2PAD20_FUNC_SPI0_CLK>, <MCXC01_PIN_50_G2PAD21_FUNC_SPI0_DO>,
						 <MCXC01_PIN_51_G2PAD22_FUNC_SPI0_DI>, <MCXC01_PIN_52_G2PAD23_FUNC_GPIO8_3>;
			};
		};
		spi1_pins_11:spi1_pins_11 {
			pins1 {
				pinmux = <MCXC01_PIN_16_G1PAD6_FUNC_SPI1_CLK>, <MCXC01_PIN_17_G1PAD7_FUNC_GPIO4_7>,//11*11
						 <MCXC01_PIN_18_G1PAD8_FUNC_SPI1_DO>, <MCXC01_PIN_19_G1PAD9_FUNC_SPI1_DI>;
			};
		};
		spi1_pins_13:spi1_pins_13 {
			pins1 {
				pinmux = <MCXC01_PIN_60_G3PAD5_FUNC_SPI1_CLK>, <MCXC01_PIN_61_G3PAD6_FUNC_GPIO10_0>,//13*13
						 <MCXC01_PIN_62_G3PAD7_FUNC_SPI1_DO>, <MCXC01_PIN_63_G3PAD8_FUNC_SPI1_DI>;
			};
		};
		sdmmc0_pins:sdmmc0_pins {
			pins1 {
				pinmux = <MCXC01_PIN_48_G2PAD19_FUNC_SD0_CD>, <MCXC01_PIN_49_G2PAD20_FUNC_SD0_CLK>,
				<MCXC01_PIN_50_G2PAD21_FUNC_SD0_CMD>, <MCXC01_PIN_51_G2PAD22_FUNC_SD0_D0>,
				<MCXC01_PIN_52_G2PAD23_FUNC_SD0_D1>, <MCXC01_PIN_53_G2PAD24_FUNC_SD0_D2>,
				<MCXC01_PIN_54_G2PAD25_FUNC_SD0_D3>;
			};
		};
		sdmmc1_pins:sdmmc1_pins {
			pins1 {
				pinmux = <MCXC01_PIN_39_G2PAD10_FUNC_SD1_CD>, <MCXC01_PIN_38_G2PAD9_FUNC_SD1_CLK>,
				<MCXC01_PIN_37_G2PAD8_FUNC_SD1_CMD>, <MCXC01_PIN_29_G2PAD0_FUNC_SD1_D0>,
				<MCXC01_PIN_30_G2PAD1_FUNC_SD1_D1>, <MCXC01_PIN_31_G2PAD2_FUNC_SD1_D2>,
				<MCXC01_PIN_32_G2PAD3_FUNC_SD1_D3>;
			};
		};
		rmii1_pins:rmii1_pins {
			pins1 {
				pinmux = <MCXC01_PIN_10_G1PAD0_FUNC_RMII_CLK>, <MCXC01_PIN_11_G1PAD1_FUNC_RGMII_TXD0>,
				<MCXC01_PIN_12_G1PAD2_FUNC_RGMII_TXEN>, <MCXC01_PIN_13_G1PAD3_FUNC_RGMII_TXD1>,
				<MCXC01_PIN_14_G1PAD4_FUNC_RGMII_RXD1>, <MCXC01_PIN_15_G1PAD5_FUNC_RGMII_RXD0>,
				<MCXC01_PIN_16_G1PAD6_FUNC_RGMII_RXDV>, <MCXC01_PIN_17_G1PAD7_FUNC_EPHY_CLK>,
				<MCXC01_PIN_18_G1PAD8_FUNC_MDCK>, <MCXC01_PIN_19_G1PAD9_FUNC_MDIO>,
				<MCXC01_PIN_20_G1PAD10_FUNC_EPHY_RSTN>, <MCXC01_PIN_22_G1PAD12_FUNC_RGMII_TXCK>,
				<MCXC01_PIN_24_G1PAD14_FUNC_RGMII_RXCK>,<MCXC01_PIN_25_G1PAD15_FUNC_RGMII_RXD2>,
				<MCXC01_PIN_26_G1PAD16_FUNC_RGMII_RXD3>, <MCXC01_PIN_27_G1PAD17_FUNC_RGMII_TXD2>,
				<MCXC01_PIN_28_G1PAD18_FUNC_RGMII_TXD3>;
			};
		};
	};

	spi0: spi@08B00000 {
	        compatible = "molchip,spi";
	        #address-cells = <1>;
	        #size-cells = <0>;
	        interrupts = <GIC_SPI 74 IRQ_TYPE_LEVEL_HIGH>;
	        reg = <0x08B00000 0x100>;
	        reg-names = "control";
	        clocks = <&cpusys_gatemux CKG_SPI0_EN>,<&cpusys_gatemux CKG_APB_SPI0_EN>,<&cpusys_compostite CKG_MUX_SPI0>;
			clock-names = "clk","spi_apb_clk","spi_mux_clk";
	        num-cs = <1>;
	        reg-io-width = <4>;
			id = <0>;
			spi-slave-mode = <0>;
			cs-gpios = <&gpio8 3 0>;
			pinctrl-names = "default";
			pinctrl-0 = <&spi0_pins>;
	        status = "disabled";

	        dev@0 {
	                compatible = "spi,dev";
	                reg = <0>;
	                spi-max-frequency = <36000000>;
	        };
	};

	spi1: spi@08C00000 {
	        compatible = "molchip,spi";
	        #address-cells = <1>;
	        #size-cells = <0>;
	        interrupts = <GIC_SPI 73 IRQ_TYPE_LEVEL_HIGH>;
	        reg = <0x08C00000 0x100>;
	        reg-names = "control";
	        clocks = <&cpusys_gatemux CKG_SPI1_EN>,<&cpusys_gatemux CKG_APB_SPI1_EN>,<&cpusys_compostite CKG_MUX_SPI1>;
			clock-names = "clk","spi_apb_clk","spi_mux_clk";
	        num-cs = <1>;
	        reg-io-width = <4>;
			id = <1>;
			spi-slave-mode = <0>;
	        status = "okay";

	        dev@0 {
	                compatible = "spi,dev";
	                reg = <0>;
	                spi-max-frequency = <36000000>;
	        };
	};

	perfmon@24800000{
		compatible = "mc,perfmon";
		reg = <0x24800000  0x400>;
		molchip,syscon =<&dmc_sys_apb>;
		dfimon-time-ctrl-offset-reg = <0x00>;
		dfimon-time-ctrl-offset-bit = <0x1>;
		dfimon-time-en-ctrl-offset-bit = <0x0>;
		dfimon-time-low-ctrl-offset-reg = <0x08>;
		dfimon-time-high-ctrl-offset-reg = <0x04>;
		perfmon,channel-num = <5>;
		status = "okay";
	};
	i2s0: i2s@08900000 {
		compatible = "molchip,i2s";
		i2s_id = <0>;
		reg = < 0x08900000  0x100>, /*i2s0: base*/
				< 0x0C000000  0x200>; /*ap_sys_apb_base*/
		interrupts = <GIC_SPI 30 IRQ_TYPE_LEVEL_HIGH>;
		molchip,softreset-reg = <0xc>;
		molchip,softreset-bit = <7>;
		molchip,dma-rx-id = <24>;
		molchip,dma-tx-id = <25>;
		molchip,i2sworkclk_mclk_same_clksource_en = <0x0>; /* when i2s as slave there should equal 0 */
		molchip,i2stransprotocol_leftjustified_en = <0x0>;
		status = "okay";
	};

	i2s1: i2s@08a00000 {
		compatible = "molchip,i2s";
		i2s_id = <1>;
		reg = <0x08a00000  0x100>, /*i2s1: base*/
				<0x0C000000  0x200>; /*ap_sys_apb_base*/
		interrupts = <GIC_SPI 31 IRQ_TYPE_LEVEL_HIGH>;
		molchip,softreset-reg = <0xc>;
		molchip,softreset-bit = <8>;
		molchip,dma-rx-id = <26>;
		molchip,dma-tx-id = <27>;
		molchip,i2sworkclk_mclk_same_clksource_en = <0x0>; /* when i2s as slave there should equal 0 */
		molchip,i2stransprotocol_leftjustified_en = <0x0>;
		status = "okay";
	};

	src: src@09600000 {
		compatible = "molchip,src";
		reg = <0x09600000 0x200>,
				<0x09200200 0x60>,
				<0x0c000000 0x100>;
		clocks = <&cpusys_gatemux CKG_APB_SRC_EN>,<&cpusys_gatemux CKG_SRC_EN>,<&cpusys_compostite CKG_MUX_SRC>;
		clock-names = "ckg_apb_src_en","ckg_src_en","ckg_mux_src";
		molchip,dma-rx-id = <34>;
		molchip,dma-tx-id = <35>;
		status = "okay";
	};

	pts: pts@0x1c500000 {
		compatible = "molchip,pts";
		reg = <0x1c500000 0x1000>, <0x1c000000 0x1000>;
		clocks = <&topsys_gate CKG_PTS_EN>,<&veusys CKG_APB_PTS_EN>,
			<&topsys_compostite CKG_MUX_PTS>;
		clock-names = "ckg_pts_en","ckg_apb_pts_en","ckg_mux_pts";
		clock-freq = <1000000>;
		status = "okay";
	};
	sys_config {
		compatible = "molchip,sys_config";
		clock-names = "ckg_vpu_en",
				"ckg_ahb_vpu_en",
				"ckg_2dlut_en",
				"ckg_ahb_2dlut_en",
				"ckg_vpu",
				"ckg_ahb_isp_en",
				"ckg_isp_en",
				"ckg_isp_bus",
				"ckg_sensor0_en",
				"ckg_sensor1_en",
				"ckg_sensor2_en",
				"ckg_sensor0",
				"ckg_sensor1",
				"ckg_sensor2";
		clocks = <&ispsys CKG_VPU_EN>,
				<&ispsys CKG_AHB_VPU_EN>,
				<&ispsys CKG_2DLUT_EN>,
				<&ispsys CKG_AHB_2DLUT_EN>,
				<&ispsys CKG_MUX_VPU>,
				<&ispsys CKG_AHB_ISP_EN>,
				<&ispsys CKG_ISP_EN>,
				<&ispsys CKG_MUX_ISP_BUS>,
				<&topsys_gate CKG_SENSOR0_EN>,
				<&topsys_gate CKG_SENSOR1_EN>,
				<&topsys_gate CKG_SENSOR2_EN>,
				<&topsys_compostite CKG_MUX_SENSOR0>,
				<&topsys_compostite CKG_MUX_SENSOR1>,
				<&topsys_compostite CKG_MUX_SENSOR2>;
		status = "okay";
	};
};
