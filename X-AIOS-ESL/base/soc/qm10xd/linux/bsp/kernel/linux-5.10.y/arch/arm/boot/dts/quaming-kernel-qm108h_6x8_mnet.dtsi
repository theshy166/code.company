		clocks = <&cpusys_gatemux CKG_I2C1_EN>,<&cpusys_gatemux CKG_APB_I2C1_EN>,<&cpusys_compostite CKG_MUX_I2C1>;
		clock-names = "clk","i2c_apb_clk","i2c_mux_clk";
