		#size-cells = <0>;
		compatible = "molchip,i2c";
		reg = <0x09300000 0x100>;
		clocks = <&cpusys_gatemux CKG_I2C3_EN>,<&cpusys_gatemux CKG_APB_I2C3_EN>,<&cpusys_compostite CKG_MUX_I2C3>;
		clock-names = "clk","i2c_apb_clk","i2c_mux_clk";
		interrupts = <GIC_SPI 69 IRQ_TYPE_LEVEL_HIGH>;
		clock-frequency = <400000>;
		i2c-sda-hold-time-ns = <0xc8>;
		i2c-sda-falling-time-ns = <200>;
		i2c-scl-falling-time-ns = <200>;
