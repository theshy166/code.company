# Note: Buildroot's and Meson's terminologies differ about the meaning
# of 'build', 'host' and 'target':
# - Buildroot's 'host' is Meson's 'build'
# - Buildroot's 'target' is Meson's 'host'

[binaries]
c = '/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/bin/arm-molv2-linux-uclibcgnueabi-gcc'
cpp = '/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/bin/arm-molv2-linux-uclibcgnueabi-g++'
ar = '/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/bin/arm-molv2-linux-uclibcgnueabi-gcc-ar'
strip = '/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/bin/arm-molv2-linux-uclibcgnueabi-strip'
pkgconfig = '/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/bin/pkgconf'
g-ir-compiler = '/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/arm-molv2-linux-uclibcgnueabi/sysroot/usr/bin/g-ir-compiler'
g-ir-scanner = '/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/arm-molv2-linux-uclibcgnueabi/sysroot/usr/bin/g-ir-scanner'

[built-in options]
c_args = ['-D_LARGEFILE_SOURCE', '-D_LARGEFILE64_SOURCE', '-D_FILE_OFFSET_BITS=64', '-Os', '-g0'@PKG_TARGET_CFLAGS@]
c_link_args = [@PKG_TARGET_LDFLAGS@]
cpp_args = ['-D_LARGEFILE_SOURCE', '-D_LARGEFILE64_SOURCE', '-D_FILE_OFFSET_BITS=64', '-Os', '-g0'@PKG_TARGET_CXXFLAGS@]
cpp_link_args = [@PKG_TARGET_LDFLAGS@]
wrap_mode = 'nodownload'

[properties]
needs_exe_wrapper = true
sys_root = '/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/arm-molv2-linux-uclibcgnueabi/sysroot'
pkg_config_libdir = '/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/arm-molv2-linux-uclibcgnueabi/sysroot/usr/lib/pkgconfig:/data/jenkins/bin/toolchain/arm-molv2-linux-uclibcgnueabi/arm-molv2-linux-uclibcgnueabi/sysroot/usr/share/pkgconfig'
pkg_config_static = 'false'

[host_machine]
system = 'linux'
cpu_family = 'arm'
cpu = 'cortex-a7'
endian = 'little'
