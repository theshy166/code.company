#
# Esl Features
#
CONFIG_XOS_PROJECT_TYPE="esl2"
CONFIG_QM_VERSION="V2.0.3"
CONFIG_QM_HW_VERSION="10"
CONFIG_PLATFORM_ID="ESL10D"
# CONFIG_DISABLE_UPDATE is not set
# CONFIG_LCD_PANEL is not set
# CONFIG_TOUCH_PANEL is not set
# CONFIG_WIFI_SUPPORT is not set
CONFIG_XOS_WIFI_QUADRV="aic8800d"
# CONFIG_ETHERNET_SUPPORT is not set
# end of Esl Features

#
# SoC System
#

#
# Chipset family 
#
# CONFIG_CHIPSET_MC331X is not set
# CONFIG_CHIPSET_QM10XH is not set
# CONFIG_CHIPSET_QM10XV is not set
CONFIG_CHIPSET_QM10XD=y
# CONFIG_CHIPSET_SIMULATOR is not set
CONFIG_CHIPSET_QM102D=y
# CONFIG_CHIPSET_QM101D is not set
# end of Chipset family 

#
# OS Configure
#
CONFIG_OS_LINUX=y
# CONFIG_OS_RTT is not set

#
# Uboot
#
CONFIG_UBOOT_DEFCONFIG="quaming_qm10xd_esl_defconfig"
CONFIG_UBOOT_VERSION="v1.0"
# CONFIG_UBOOT_FEATURE_FB_MODE is not set
CONFIG_UBOOT_FEATURE_FASTBOOT_FLASH=y
CONFIG_UBOOT_FEATURE_UDISK_FLASH=y
CONFIG_QM_MAX_SPLIT_SIZE=268435456
CONFIG_UBOOT_BOARD_NAME="NAME_NOT_DEFINED"
# end of Uboot

#
# Kernel
#
CONFIG_KERNEL_DEFCONFIG="quaming_qm10xd_esl_defconfig"
CONFIG_KERNEL_VERSION="linux-5.10.y"
CONFIG_KERNEL_DTB="quaming-kernel-qm10xd-esl.dtb"
CONFIG_QM_OS_MEM=""
CONFIG_KERNEL_BOARD_NAME="NAME_NOT_DEFINED"
# end of Kernel

#
# Rootfs
#
CONFIG_ROOTFS_VERSION="v1.0"
CONFIG_ROOTFS_BUSYBOX_CONFIG="busybox_quaming_config"
CONFIG_ROOTFS_BUSYBOX_VERSION="1.36.1"
CONFIG_ROOTFS_FORMAT="xz"
# CONFIG_XOS_SQUASHFS_USE_LZO_COMPR is not set
# end of Rootfs
# end of OS Configure

#
# Toolchain
#
# CONFIG_TOOLCHAIN_ARC-FULLHAN-ELF32 is not set
# CONFIG_TOOLCHAIN_ARM-LINUX-FHV512 is not set
# CONFIG_TOOLCHAIN_ARM-LINUX-MOLCHIP is not set
# CONFIG_TOOLCHAIN_ARM-LINUX-MOLV510 is not set
# CONFIG_TOOLCHAIN_ARM-LINUX-MUSLEABI is not set
