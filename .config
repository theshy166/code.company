CONFIG_TOOLCHAIN_ARM-LINUX-MOLV2=y
# CONFIG_TOOLCHAIN_ARM-FULLHANV2-EABI is not set
# CONFIG_TOOLCHAIN_ARM-LINUX-FHVA12C is not set
# end of Toolchain

#
# Misc Configure
#
CONFIG_XOS_BUILD_SDK="qm10xd_linux"
CONFIG_XOS_BUILD_BOARD="qm10xd"
CONFIG_XOS_SDK_NAME="qm10xd_sdk"
CONFIG_XOS_SDK_PATH="base/soc/qm10xd/linux"
# CONFIG_XOS_USE_NO_QUAUI is not set
# CONFIG_XOS_USE_DLMPI is not set
# CONFIG_XOS_USE_DTEST is not set
CONFIG_STORAGE_TYPE=""
# end of Misc Configure
# end of SoC System

#
# System Partition
#

#
# System storage
#
# CONFIG_STORAGE_TYPE_SPINOR is not set
CONFIG_STORAGE_TYPE_SPINAND=y
# CONFIG_STORAGE_TYPE_EMMC is not set
CONFIG_STORAGE_SIZE_128MB=y
# CONFIG_STORAGE_SIZE_256MB is not set
# CONFIG_STORAGE_SIZE_512MB is not set
# CONFIG_STORAGE_SIZE_1G is not set
# end of System storage

#
# Partition
#
CONFIG_QM_SYS_PARTI_NAME_LIST="uboot recovery boot logo system rootfs data"
CONFIG_QM_SYS_PARTI_INFOFILE="partition-info.txt"
CONFIG_QM_SYS_PARTI_DEFAULT_FS_TYPE="ext4"
# end of Partition
# end of System Partition

