    bool "ipc"
    help
      Configuration for ipc.

config PRODUCT_GALLERY
    bool "gallery"
    help
      Configuration for gallery.

config PRODUCT_SMARTHOME
    bool "smarthome"
    help
      Configuration for smarthome.

