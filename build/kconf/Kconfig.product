#XOS Product Configure
#
menu "XOS Product"

choice
    prompt "XOS Product"
    default PRODUCT_AICAMERA

config PRODUCT_AICAMERA
    bool "aicamera"
    ## select XOS_USE_APP_AICAMERA
    ## add select more features here
    help
      Configuration for aicamera.

