cmake_minimum_required(VERSION 3.13)

set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR arm)

MESSAGE(STATUS "toolchain select")

# option
#set(CMAKE_SYSROOT )
#set(CMAKE_STAGING_PREFIX )

set(XOS_ROOT $ENV{XOS_ROOT})
MESSAGE(STATUS "XOS_ROOT: ${XOS_ROOT}")
MESSAGE(STATUS "CMAKE_CURRENT_SOURCE_DIR: ${CMAKE_CURRENT_SOURCE_DIR}")

set(tools ${XOS_ROOT}/tools/toolchain/arm-fhva12c-linux-uclibcgnueabihf-b6)
set(CMAKE_C_COMPILER ${tools}/bin/arm-fhva12c-linux-uclibcgnueabihf-gcc)
set(CMAKE_CXX_COMPILER ${tools}/bin/arm-fhva12c-linux-uclibcgnueabihf-g++)

set(CMAKE_C_FLAGS_INIT "-std=gnu99")

set(CMAKE_ASM_OUTPUT_EXTENSION .o)
set(CMAKE_C_OUTPUT_EXTENSION .o)
set(CMAKE_CXX_OUTPUT_EXTENSION .o)

set(CMAKE_EXECUTABLE_SUFFIX_ASM .elf)
set(CMAKE_EXECUTABLE_SUFFIX_C .elf)
set(CMAKE_EXECUTABLE_SUFFIX_CXX .elf)

set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
